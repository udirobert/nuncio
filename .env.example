# TinyFish — profile enrichment
TINYFISH_API_KEY=

# Anthropic — script generation (optional if Featherless is set)
ANTHROPIC_API_KEY=
ANTHROPIC_TIMEOUT_MS=15000

# Featherless AI — open-weight LLM fallback (OpenAI-compatible)
# Used if ANTHROPIC_API_KEY is not set. Supports Qwen3, DeepSeek, Llama, etc.
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=deepseek-ai/DeepSeek-V4-Flash
FEATHERLESS_TIMEOUT_MS=15000

# HeyGen — video rendering
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# Melius — creative canvas MCP
MELIUS_API_KEY=
MELIUS_RUN_TIMEOUT_SECONDS=30

# Fal — optional image generation fallback when MELIUS_API_KEY is not set
FAL_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/schnell

# Speechmatics — speech-to-text
SPEECHMATICS_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set NEXT_PUBLIC_DEMO_MODE=true to force demo mode on all page loads
# NEXT_PUBLIC_DEMO_MODE=false

# PostHog — product analytics
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NUNCIO_DATA_DIR=.data

# Storage — production share metadata. If unset, falls back to file storage.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Grove — optional public/redacted proof publishing. Disabled by default.
GROVE_ENABLED=false
GROVE_API_URL=https://api.grove.storage
GROVE_CHAIN_ID=37111

# Stripe — payments (optional; app runs without it)
# Use test keys for development
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Create products in Stripe Dashboard and add their price IDs here
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=
