{
  "name": "nuncio",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke.mjs",
    "golden": "node scripts/golden-path.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@gsap/react": "2.1.2",
    "@libsql/client": "0.17.3",
    "@posthog/react": "1.9.0",
    "@sentry/nextjs": "10.53.1",
    "@speechmatics/auth": "0.1.0",
    "@speechmatics/batch-client": "5.2.0",
    "framer-motion": "12.38.0",
    "gsap": "3.15.0",
    "ioredis": "5.10.1",
    "lenis": "1.3.23",
    "motion": "12.38.0",
    "next": "16.2.6",
    "posthog-js": "1.373.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "6.12.3",
    "stripe": "22.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'pnpm exec tsc --noEmit'"
    ],
    "*.{js,mjs}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@sentry/cli"]
  }
}
