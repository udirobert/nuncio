# Band of Agents — environment variables
# Copy to .env and fill in your values.

# Band platform API key (shared across all agents)
BAND_API_KEY=

# Agent IDs (create each agent on app.band.ai first)
BAND_RESEARCHER_AGENT_ID=
BAND_COPYWRITER_AGENT_ID=
BAND_REVIEWER_AGENT_ID=
BAND_PRODUCER_AGENT_ID=

# Nuncio API base URL (where the Next.js app is running)
NUNCIO_API_URL=http://localhost:3000

# Internal workspace ID for credit accounting (optional)
NUNCIO_BAND_WORKSPACE_ID=band-internal
